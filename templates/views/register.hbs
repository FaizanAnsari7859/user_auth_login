<form action="/register" method="POST">
<div class="container register">
                <div class="row">
                    <div class="col-md-3 register-left">
                        <img src="/css/img/image.jpg" alt="img"/>
                        <h3>Welcome</h3>
                        
                        <p>complete MEAN BackEnd course</p>

                        <a href="/login"><input type="submit" name="login" value="Login"/></a><br/>
